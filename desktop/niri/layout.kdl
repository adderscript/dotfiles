prefer-no-csd

layout {
    gaps 6
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        off
        width 4

        active-color "#7fc8ff"
        inactive-color "#505050"
    }

    border {
        on

        width 3
        active-color "#ddccf2"
        inactive-color "#4d4c4c"
        urgent-color "#9b0000"
    }
}
