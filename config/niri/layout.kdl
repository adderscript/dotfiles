prefer-no-csd

layout {
    gaps 8
    background-color "#181825"

    focus-ring {
        on
        width 2

        active-color "#88ccfa"
        inactive-color "#11111b"
        urgent-color   "#ffb4ab"
    }

    border {
        off
        width 2

        active-color "#88ccfa"
        inactive-color "#11111b"
        urgent-color   "#ffb4ab"
    }

    shadow {
        on
        softness 20
        spread 5
        offset x=0 y=5
        draw-behind-window true
        color "#00000088"
    }

    tab-indicator {
        active-color   "#f1be6d"
        inactive-color "#18130b"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#f1be6d80"
    }
}

overview {
    backdrop-color "#181825"
}
